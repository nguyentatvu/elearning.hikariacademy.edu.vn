# public/ is mounted on gcsfuse (Google Cloud Storage) on staging/production.
# Tracking these files makes git operations extremely slow and expensive.
# We exclude everything in public/ except the small set of entry-point files.
/public/*
!/public/index.php
!/public/.htaccess
!/public/web.config
!/public/robots.txt
!/public/favicon.ico