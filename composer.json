{
    "name": "laravel/laravel",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "type": "project",
    "require": {
        "php": ">=7.0.0",
        "anhskohbo/no-captcha": "^3.0",
        "barryvdh/laravel-debugbar": "3.2.9",
        "barryvdh/laravel-dompdf": "^0.8.2",
        "cmgmyr/messenger": "^2.14",
        "consoletvs/charts": "^6.7.0",
        "darkaonline/l5-swagger": "5.5.8",
        "doctrine/annotations": "^1.10",
        "doctrine/dbal": "^2.6",
        "dompdf/dompdf": "0.8.2",
        "fideloper/proxy": "~3.3",
        "google/cloud-text-to-speech": "^1.2",
        "intervention/image": "^2.3",
        "jenssegers/date": "^3.0",
        "laravel/cashier": "^7.0",
        "laravel/framework": "5.5.*",
        "laravel/socialite": "^3.0",
        "laravel/tinker": "~1.0",
        "laravelcollective/html": "^5.3.0",
        "lcobucci/jwt": "3.3.3",
        "maatwebsite/excel": "~2.1.0",
        "milon/barcode": "^5.3",
        "shipu/themevel": "^1.6",
        "spipu/html2pdf": "^5.2",
        "tymon/jwt-auth": "1.0.0-rc.4",
        "yajra/laravel-datatables-oracle": "8.0.0",
        "zircote/swagger-php": "2.0",
        "firebase/php-jwt": "*",
        "zizaco/entrust": "dev-laravel-5"
    },
    "require-dev": {
        "filp/whoops": "~2.0",
        "fzaninotto/faker": "~1.4",
        "mockery/mockery": "0.9.*",
        "phpunit/phpunit": "~6.0",
        "symfony/css-selector": "3.1.*",
        "symfony/dom-crawler": "3.1.*"
    },
    "autoload": {
        "classmap": [
            "database/seeds",
            "database/factories"
        ],
        "psr-4": {
            "App\\": "app/"
        },
        "files":[
            "app/constants.php",
            "app/helpers.php",
            "app/language_helper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": [
            ]
        }
    },
    "scripts": {
        "post-root-package-install": [
            "php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "php artisan key:generate"
        ],
        "post-install-cmd": [
            "Illuminate\\Foundation\\ComposerScripts::postInstall",
            "php artisan optimize"
        ],
        "post-update-cmd": [
            "Illuminate\\Foundation\\ComposerScripts::postUpdate",
            "php artisan optimize"
        ]
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "kylekatarnls/update-helper": true
        }
    }
}
